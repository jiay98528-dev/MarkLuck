{
  "name": "markluck",
  "version": "0.0.0",
  "private": true,
  "description": "Lightweight, local-first Markdown note-taking tool",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @markluck/app dev",
    "build": "pnpm --filter @markluck/app build",
    "preview": "pnpm --filter @markluck/app preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check \"**/*.{ts,vue,css,json,md,yaml}\"",
    "format:fix": "prettier --write \"**/*.{ts,vue,css,json,md,yaml}\"",
    "typecheck": "pnpm --filter @markluck/app typecheck",
    "test": "cd packages/app && vitest run",
    "test:watch": "cd packages/app && vitest",
    "test:coverage": "cd packages/app && vitest run --coverage",
    "test:e2e": "cd packages/app && playwright test",
    "test:e2e:ui": "cd packages/app && playwright test --ui",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.css": [
      "prettier --write"
    ],
    "*.{json,md,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@playwright/test": "^1.60.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vue/test-utils": "^2.4.10",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.60.1",
    "vitest": "^2.1.0",
    "vue-eslint-parser": "^10.4.1"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@11.5.1"
}
