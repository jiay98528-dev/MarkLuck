{
  "name": "markluck",
  "version": "0.15.0",
  "private": true,
  "description": "Lightweight, local-first Markdown note-taking tool",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @markluck/app dev",
    "build": "pnpm --filter @markluck/app build",
    "preview": "pnpm --filter @markluck/app preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check \"*.json\" \".github/**/*.yml\" \"AGENTS.md\" \"CLAUDE.md\" \"doc/**/*.md\" \"spec/**/*.md\" \"memory/**/*.md\" \"e2e/**/*.ts\" \"packages/**/*.{ts,vue,css,json,md,yaml}\"",
    "format:fix": "prettier --write \"*.json\" \".github/**/*.yml\" \"AGENTS.md\" \"CLAUDE.md\" \"doc/**/*.md\" \"spec/**/*.md\" \"memory/**/*.md\" \"e2e/**/*.ts\" \"packages/**/*.{ts,vue,css,json,md,yaml}\"",
    "test": "pnpm --filter @markluck/app test",
    "test:coverage": "pnpm --filter @markluck/app test:coverage",
    "audit:rust": "cargo audit --file packages/app/src-tauri/Cargo.lock",
    "release:rc-gate": "node scripts/release-rc-gate.mjs",
    "typecheck": "pnpm --filter @markluck/app typecheck",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.css": [
      "prettier --write"
    ],
    "*.{json,md,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@playwright/test": "^1.60.0",
    "@types/js-yaml": "^4.0.9",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.60.1",
    "vue-eslint-parser": "^10.4.1"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@11.5.1",
  "dependencies": {
    "docx": "^9.7.1",
    "js-yaml": "^4.2.0",
    "minisearch": "^7.2.0"
  }
}
