{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "JotLuck default capabilities - dialog and shell only; file I/O uses custom Rust commands",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask",
    "shell:default"
  ]
}
