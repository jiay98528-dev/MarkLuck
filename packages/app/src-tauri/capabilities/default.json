{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "MarkLuck default capabilities — filesystem, dialog, shell",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "fs:default",
    "fs:allow-read",
    "fs:allow-write",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-rename",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask",
    "shell:default",
    "shell:allow-open",
    "process:default"
  ]
}
