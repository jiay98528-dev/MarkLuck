{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MarkLuck",
  "version": "0.15.0",
  "identifier": "com.markluck.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "MarkLuck",
        "label": "main",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "maximized": true,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "icons/file-icon.ico": "file-icon.ico"
    },
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mdx"],
        "name": "MarkLuck.Markdown",
        "description": "Markdown Document",
        "role": "Editor"
      }
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": true
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "headerImage": "installer-assets/header.bmp",
        "uninstallerHeaderImage": "installer-assets/header.bmp",
        "sidebarImage": "installer-assets/sidebar.bmp",
        "installMode": "currentUser",
        "languages": ["SimpChinese", "English"],
        "customLanguageFiles": {
          "SimpChinese": "installer-assets/SimpChinese.nsh",
          "English": "installer-assets/English.nsh"
        },
        "installerHooks": "installer-assets/hooks.nsh",
        "displayLanguageSelector": true
      }
    },
    "macOS": {
      "minimumSystemVersion": "11.0",
      "dmg": {
        "appPosition": { "x": 180, "y": 170 },
        "applicationFolderPosition": { "x": 480, "y": 170 }
      }
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0", "libayatana-appindicator3-1"]
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
