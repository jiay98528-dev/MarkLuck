{
  "name": "@markluck/app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint:style": "stylelint \"src/**/*.{vue,css}\"",
    "lint:style:fix": "stylelint \"src/**/*.{vue,css}\" --fix",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report ../../e2e/report",
    "test:e2e:stable": "playwright test --project=chromium --workers=1",
    "test:e2e:chromium": "playwright test --project=chromium --workers=1",
    "test:e2e:firefox": "playwright test --project=firefox --workers=1",
    "test:e2e:webkit": "playwright test --project=webkit --workers=1",
    "tauri": "cargo tauri",
    "tauri:dev": "cargo tauri dev",
    "tauri:build": "cargo tauri build",
    "tauri:build:debug": "cargo tauri build --debug"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@lezer/highlight": "^1.2.3",
    "@markluck/renderer": "workspace:*",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "docx": "^9.7.1",
    "dompurify": "^3.4.7",
    "marked": "^18.0.4",
    "pinia": "^2.2.0",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@vitejs/plugin-vue": "^5.1.0",
    "@vue/test-utils": "^2.4.11",
    "happy-dom": "^20.10.3",
    "jsdom": "^29.1.1",
    "postcss-html": "^1.8.1",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^40.0.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0",
    "vue-tsc": "^2.1.0"
  }
}
